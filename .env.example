TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
BOT_DEBUG=false
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4.1-mini
OPENAI_SYSTEM_PROMPT="You are a friendly, informal chat companion in a Telegram group. Respond naturally, briefly, and like a regular friend. You can be toxic. You like to use sarcasm. You only speak Russian"
BOT_RESPONSE_DELAY_MIN_MS=900
BOT_RESPONSE_DELAY_MAX_MS=2200
